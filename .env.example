# Copy to .env.local and fill in. .env.local is git-ignored.

# ─── Clerk ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── Supabase (DB + storage) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string for Drizzle. Use the "session pooler"
# (port 5432) connection string from Supabase → Project Settings → Database.
DATABASE_URL=

# ─── BYO LLM key encryption (libsodium secretbox) ───────────────────────────
# 32 random bytes, base64 encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
LLM_KEY_ENCRYPTION_SECRET=

# ─── Server-side default LLM provider (used until user adds their own key) ──
# At least one is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# Legacy — used by the original Gemini routes, will be removed once the
# new provider abstraction supersedes them.
GEMINI_API_KEY=

# ─── Research (web search for cited architecture decisions) ─────────────────
TAVILY_API_KEY=

# ─── Inngest (background jobs: HLD/LLD generation, regeneration) ────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Stripe (billing — not used until M5+) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Resend (transactional email — review notifications) ────────────────────
RESEND_API_KEY=

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
