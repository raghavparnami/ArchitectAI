# Copy to .env.local and fill in. .env.local is git-ignored.

# ─── Clerk ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── SQLite ─────────────────────────────────────────────────────────────────
# better-sqlite3 takes a file path; the file is created on first connect.
# Relative paths resolve against the project root.
DATABASE_URL=./architectai.db

# ─── Gemini (sole built-in LLM provider) ────────────────────────────────────
# The Vercel AI SDK reads GOOGLE_GENERATIVE_AI_API_KEY; we mirror it to
# GEMINI_API_KEY so the legacy /api/ai/* routes keep working until M2.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=

# ─── BYO LLM key encryption (libsodium secretbox) ───────────────────────────
# 32 random bytes, base64 encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
LLM_KEY_ENCRYPTION_SECRET=

# ─── Inngest (background jobs: HLD generation, regeneration) ────────────────
# For local dev, run: npx inngest-cli@latest dev
# These are only required when pointing at Inngest Cloud.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Optional / unused in the SQLite-Gemini prototype ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
RESEND_API_KEY=

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
